# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# WPS Open Platform (for data sync API)
VITE_WPS_APP_ID="your_wps_app_id_here"
VITE_WPS_APP_KEY="your_wps_app_key_here"
VITE_WPS_SPREADSHEET_ID="your_spreadsheet_id_here"
VITE_WPS_API_BASE="https://openapi.wps.cn"
VITE_WPS_DEFAULT_RANGE="Sheet1!A1:Z1000"
# Redirect URI for OAuth callback (defaults to current origin if not set)
VITE_WPS_REDIRECT_URI="your_redirect_uri_here"

# WPS WebOffice (for embedded document preview)
# Separate App ID/Secret because WebOffice uses different app
VITE_WEB_OFFICE_APP_ID="your_weboffice_app_id_here"
VITE_WEB_OFFICE_APP_SECRET="your_weboffice_app_secret_here"
